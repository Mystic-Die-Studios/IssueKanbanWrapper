# This is a dynamic, session-based app — never let LiteSpeed/Apache cache it.
# (Caching the OAuth login redirect replays a stale `state` and breaks sign-in.)
<IfModule LiteSpeed>
  RewriteEngine On
  RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

<IfModule mod_headers.c>
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
</IfModule>
